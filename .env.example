# Copy this file to .env and fill in your keys. .env is git-ignored.
TAVILY_API_KEY=tvly-your-key-here

# Used by later steps (Prometheux brain, ClickHouse storage):
PMTX_TOKEN=
PMTX_API_URL=
CLICKHOUSE_URL=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=

# Paywall: password that unlocks the full cited report (dev demo unlock)
DEV_UNLOCK_PASSWORD=

# x402 agent payment (Base Sepolia testnet — free, no real money)
# X402_PAY_TO is a PUBLIC receiving address (not a secret). The server needs
# only this to issue a 402 and verify payments via the public facilitator.
X402_PAY_TO=0xYourTestnetReceivingAddress
X402_NETWORK=base-sepolia
X402_PRICE=$0.01
# Private key is for the PAYER side only (a wallet funded with test USDC).
# The server never uses it. Throwaway testnet key only — never commit.
X402_WALLET_PRIVATE_KEY=
